  "type": "module",
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@monaco-editor/react": "^4.6.0",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.10",
    "@tanstack/react-query": "^5.100.7",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "firebase": "^11.10.0",
    "katex": "^0.16.45",
    "liquidjs": "^10.25.7",
    "monaco-editor": "^0.52.2",
    "openapi-fetch": "^0.12.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^6.30.3",
    "react-use": "^17.3.1",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "smol-toml": "^1.6.1",
    "unified": "^11.0.5",
    "url-join": "^5.0.0"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "prettier": "prettier --write \"src/**/*.{ts,js,tsx,jsx}\"",
    "prettier:check": "prettier --check \"src/**/*.{ts,js,tsx,jsx}\"",
    "openapi:gen": "openapi-typescript ../restapi/openapi/openapi.yaml -o src/openapi/types.ts && prettier --write src/openapi/types.ts",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@typescript-eslint/typescript-estree": "^8.59.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
